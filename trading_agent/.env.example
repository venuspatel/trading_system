# ============================================================
#  Trading Agent — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# ── Active provider ──────────────────────────────────────────
# Options: alpaca | ibkr | binance
ACTIVE_PROVIDER=alpaca

# ── Alpaca ───────────────────────────────────────────────────
# Get keys at: https://app.alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true          # true = paper trading, false = live (be careful!)

# ── IBKR (stub — not needed yet) ─────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497             # 7497 = paper, 7496 = live
IBKR_CLIENT_ID=1

# ── Binance (stub — not needed yet) ──────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=true

# ── Watchlist ─────────────────────────────────────────────────
# Comma-separated, no spaces
WATCHLIST=AAPL,TSLA,NVDA,MSFT,AMZN

# ── Data settings ─────────────────────────────────────────────
DEFAULT_TIMEFRAME=1Day
BAR_CACHE_SIZE=500
WARMUP_DAYS=60

# ── Logging ───────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Anthropic API key for AI trade reviewer
ANTHROPIC_API_KEY=your_anthropic_api_key_here
