import React, { useState, useEffect, useRef } from 'react';
import Dashboard from './components/Dashboard';
import ConfigPanel from './components/ConfigPanel';
import Positions from './components/Positions';
import History from './components/History';
import Settings from './components/Settings';

const NAV = [
  { id: 'dashboard', icon: Dashboard_Icon },
  { id: 'positions', icon: Positions_Icon },
  { id: 'history',   icon: History_Icon   },
  { id: 'config',    icon: Config_Icon    },
  { id: 'settings',  icon: Settings_Icon  },
];

function Dashboard_Icon({ active }) {
  return (
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
      <rect x="2" y="2" width="6" height="6" rx="1.5" fill={active ? '#4d9cf8' : '#333'}/>
      <rect x="10" y="2" width="6" height="6" rx="1.5" fill={active ? '#4d9cf8' : '#333'} opacity={active ? .4 : 1}/>
      <rect x="2" y="10" width="6" height="6" rx="1.5" fill={active ? '#4d9cf8' : '#333'} opacity={active ? .4 : 1}/>
      <rect x="10" y="10" width="6" height="6" rx="1.5" fill={active ? '#4d9cf8' : '#333'} opacity={active ? .4 : 1}/>
    </svg>
  );
}
function Positions_Icon({ active }) {
  return (
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
      <path d="M2 14 L6 9 L10 11 L16 4" stroke={active ? '#4d9cf8' : '#333'} strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/>
    </svg>
  );
}
function History_Icon({ active }) {
  return (
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
      <path d="M3 5h12M3 9h8M3 13h10" stroke={active ? '#4d9cf8' : '#333'} strokeWidth="1.5" strokeLinecap="round"/>
    </svg>
  );
}
function Config_Icon({ active }) {
  return (
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
      <circle cx="9" cy="9" r="2.5" stroke={active ? '#4d9cf8' : '#333'} strokeWidth="1.5"/>
      <path d="M9 2v2M9 14v2M2 9h2M14 9h2" stroke={active ? '#4d9cf8' : '#333'} strokeWidth="1.5" strokeLinecap="round"/>
    </svg>
  );
}
function Settings_Icon({ active }) {
  return (
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
      <circle cx="9" cy="7" r="3" stroke={active ? '#4d9cf8' : '#333'} strokeWidth="1.5"/>
      <path d="M3 16c0-3.314 2.686-5 6-5s6 1.686 6 5" stroke={active ? '#4d9cf8' : '#333'} strokeWidth="1.5" strokeLinecap="round"/>
    </svg>
  );
}

const PAGES = { dashboard: Dashboard, positions: Positions, history: History, config: ConfigPanel, settings: Settings };

export default function App() {
  const [page, setPage]     = useState('dashboard');
  const [state, setState]   = useState(null);
  const [live, setLive]     = useState([]);
  const wsRef               = useRef(null);

  // Poll state every 10s
  useEffect(() => {
    const load = () => fetch('/api/state').then(r => r.json()).then(setState).catch(() => {});
    load();
    const t = setInterval(load, 10000);
    return () => clearInterval(t);
  }, []);

  // WebSocket for live decisions
  useEffect(() => {
    const ws = new WebSocket(`ws://${window.location.host}/ws`);
    wsRef.current = ws;
    ws.onmessage = (e) => {
      const msg = JSON.parse(e.data);
      if (msg.type === 'decision') {
        setLive(prev => [msg, ...prev].slice(0, 100));
      }
      if (msg.type === 'status') {
        setState(prev => prev ? { ...prev, agent_status: msg.status } : prev);
      }
      if (msg.type === 'connected' && msg.state) {
        setState(msg.state);
      }
    };
    return () => ws.close();
  }, []);

  const Page = PAGES[page] || Dashboard;

  return (
    <div style={{ display:'grid', gridTemplateColumns:'52px 1fr', gridTemplateRows:'44px 1fr',
                  height:'100vh', background:'#000', fontFamily:'system-ui,-apple-system,sans-serif' }}>

      {/* Top bar */}
      <TopBar state={state} />

      {/* Sidebar */}
      <div style={{ background:'#0a0a0a', borderRight:'1px solid #1c1c1c',
                    display:'flex', flexDirection:'column', alignItems:'center',
                    padding:'10px 0', gap:'4px' }}>
        {NAV.map(({ id, icon: Icon }) => (
          <div key={id} onClick={() => setPage(id)}
            style={{ width:36, height:36, borderRadius:8, display:'flex',
                     alignItems:'center', justifyContent:'center', cursor:'pointer',
                     background: page === id ? '#0d1f3c' : 'transparent' }}>
            <Icon active={page === id} />
          </div>
        ))}
      </div>

      {/* Main content */}
      <Page state={state} liveDecisions={live} onStateChange={setState} />
    </div>
  );
}

function TopBar({ state }) {
  const status    = state?.agent_status || 'idle';
  const paper     = state?.paper_trading !== false;
  const pnl       = state?.daily_pnl || 0;
  const portfolio = state?.portfolio_value || 0;
  const nextScan  = state?.next_scans?.[0] || '—';

  const statusColor = { running:'#22c55e', paused:'#f59e0b', stopped:'#ef4444', idle:'#444' }[status] || '#444';

  const ctrl = (action) => fetch(`/api/agent/${action}`, { method:'POST' });

  return (
    <div style={{ gridColumn:'1/3', background:'#0a0a0a', borderBottom:'1px solid #1c1c1c',
                  display:'flex', alignItems:'center', padding:'0 16px', gap:'12px' }}>
      <span style={{ fontSize:13, fontWeight:600, color:'#4d9cf8', marginRight:4 }}>TradeAgent</span>

      <div style={{ display:'flex', alignItems:'center', gap:5 }}>
        <div style={{ width:7, height:7, borderRadius:'50%', background:statusColor,
                      boxShadow: status==='running' ? `0 0 5px ${statusColor}` : 'none' }}/>
        <span style={{ fontSize:12, color:statusColor, textTransform:'capitalize' }}>{status}</span>
      </div>

      {paper && (
        <span style={{ fontSize:10, fontWeight:600, padding:'2px 8px', borderRadius:4,
                       background:'#1a1200', color:'#f59e0b', border:'1px solid #2a2000' }}>PAPER</span>
      )}

      <div style={{ width:1, height:20, background:'#1c1c1c', margin:'0 4px' }}/>
      <Metric label="Portfolio" value={`$${portfolio.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2})}`} color="#e0e0e0"/>
      <div style={{ width:1, height:20, background:'#1c1c1c', margin:'0 4px' }}/>
      <Metric label="Day P&L" value={`${pnl >= 0 ? '+' : ''}$${Math.abs(pnl).toFixed(2)}`} color={pnl >= 0 ? '#22c55e' : '#ef4444'}/>
      <div style={{ width:1, height:20, background:'#1c1c1c', margin:'0 4px' }}/>
      <Metric label="Approach" value={state?.approach || '—'} color="#e0e0e0"/>
      <div style={{ width:1, height:20, background:'#1c1c1c', margin:'0 4px' }}/>
      <Metric label="Next scan" value={nextScan} color="#a78bfa"/>

      <div style={{ marginLeft:'auto', display:'flex', gap:6 }}>
        {status === 'idle' || status === 'stopped' ? (
          <button onClick={() => ctrl('start')} style={btnStyle('#22c55e','#000')}>Start</button>
        ) : status === 'running' ? (
          <button onClick={() => ctrl('pause')} style={btnStyle('#1a1a1a','#666','1px solid #2a2a2a')}>Pause</button>
        ) : (
          <button onClick={() => ctrl('resume')} style={btnStyle('#22c55e','#000')}>Resume</button>
        )}
        <button onClick={() => ctrl('scan')} style={btnStyle('#0d1f3c','#4d9cf8','1px solid #1a3a6a')}>Scan now</button>
        <button onClick={() => ctrl('stop')} style={btnStyle('#1a0000','#ef4444','1px solid #2a0000')}>Stop</button>
      </div>
    </div>
  );
}

function Metric({ label, value, color }) {
  return (
    <div style={{ display:'flex', flexDirection:'column' }}>
      <span style={{ fontSize:10, color:'#333', lineHeight:1 }}>{label}</span>
      <span style={{ fontSize:13, fontWeight:500, color, fontVariantNumeric:'tabular-nums', lineHeight:1.4 }}>{value}</span>
    </div>
  );
}

function btnStyle(bg, color, border = 'none') {
  return { padding:'5px 12px', borderRadius:5, fontSize:11, fontWeight:500,
           background:bg, color, border, cursor:'pointer' };
}
